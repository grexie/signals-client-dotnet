<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>Grexie.Signals.Client</PackageId>
    <Version>0.1.19</Version>
    <Authors>Grexie</Authors>
    <Company>Grexie</Company>
    <Description>Typed .NET client for Grexie Signals websocket subscriptions and position management.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/grexie/signals-client-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/grexie/signals-client-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>grexie;signals;websocket;trading;position-management</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="examples/**/*.cs" />
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
</Project>
